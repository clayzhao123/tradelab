HOST=0.0.0.0
PORT=3001
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tradelab_v1
MARKET_DATA_PROVIDER=real
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL_MS=15000

# MiniMax OpenAI 兼容接口 Base（须与密钥来源一致）
# 国内 platform.minimaxi.com 密钥 → 默认即可：
# MINIMAX_OPENAI_BASE_URL=https://api.minimaxi.com/v1
# 国际 platform.minimax.io 密钥 → 取消注释：
# MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1
